FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Enable pnpm via corepack
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

# Dependency layer (cached separately from source)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY site/package.json site/package-lock.json ./site/
RUN pnpm install --frozen-lockfile

# Install Playwright + Chromium with all required OS-level dependencies
RUN node_modules/.bin/playwright install --with-deps chromium

COPY . .

# In compose/CI the GUI and sidecar are separate services.
# Wait for the GUI to be healthy before running any test suite.
CMD ["sh", "-c", "\
  echo 'Waiting for GUI at $BASE_URL...'; \
  until curl -sf \"${BASE_URL:-http://gui:3000}\" > /dev/null 2>&1; do sleep 3; done; \
  echo 'GUI ready — running unit tests'; \
  pnpm test; \
  echo 'Running e2e tests'; \
  pnpm test:e2e \
"]
