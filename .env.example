# GEMINI_API_KEY: Required for Gemini AI API calls (legacy, retained for AI Studio).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted. AI Studio injects this at runtime.
APP_URL="MY_APP_URL"

# ----- Floci GUI (Vite dev server) -----
VITE_FLOCI_ENDPOINT="http://localhost:3000/aws"
VITE_SIDECAR_URL="/sidecar"
VITE_REAL_DATA_ONLY="true"
FLOCI_PROXY_TARGET="http://floci:4566"
SIDECAR_PROXY_TARGET="http://sidecar:4317"
FLOCI_PUBLIC_BASE_URL="http://localhost:3000/aws"

# ----- Sidecar (Express AWS-CLI wrapper) -----
# Bind the sidecar listener — defaults to loopback. Compose overrides to 0.0.0.0.
SIDECAR_HOST="127.0.0.1"
SIDECAR_PORT="4317"
# Required when SIDECAR_HOST is reachable from outside the loopback. Vite forwards
# the value automatically to /sidecar requests; standalone clients must send it
# via the `x-floci-sidecar-token` header or `Authorization: Bearer <token>`.
SIDECAR_TOKEN=""
# Comma-separated CORS allowlist for direct browser access to the sidecar.
SIDECAR_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Compose publishes the sidecar port — keep it bound to the host loopback unless
# you intentionally want LAN access.
SIDECAR_BIND_HOST="127.0.0.1"
# Optional: path inside the sidecar container to a kubeconfig file for kubectl pod listings.
SIDECAR_KUBECONFIG=""

# ----- AWS defaults forwarded to the sidecar -----
AWS_DEFAULT_REGION="us-east-1"
AWS_ENDPOINT_URL="http://floci:4566"
LAMBDA_DEFAULT_ROLE_ARN="arn:aws:iam::000000000000:role/lambda-role"
