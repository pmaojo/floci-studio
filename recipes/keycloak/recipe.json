{
  "id": "keycloak",
  "name": "Keycloak + PostgreSQL",
  "description": "An open-source identity and access management solution, bundled with a robust PostgreSQL database.",
  "version": "22.0.0",
  "accessUrl": "http://localhost:{{KEYCLOAK_PORT}}",
  "variables": [
    {
      "key": "KEYCLOAK_PORT",
      "label": "External HTTP Port",
      "type": "number",
      "default": 8080,
      "description": "The host port that Keycloak will be exposed on."
    },
    {
      "key": "KEYCLOAK_ADMIN",
      "label": "Admin Username",
      "type": "text",
      "default": "admin",
      "description": "The administrator username."
    },
    {
      "key": "KEYCLOAK_ADMIN_PASSWORD",
      "label": "Admin Password",
      "type": "password",
      "default": "admin123",
      "description": "The administrator password."
    },
    {
      "key": "POSTGRES_DB",
      "label": "Database Name",
      "type": "text",
      "default": "keycloak_db",
      "description": "The database name for PostgreSQL."
    }
  ]
}
