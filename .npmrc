# Use local store cache whenever packages are already downloaded.
# Avoids hitting the registry in sessions where the container state is cached.
prefer-offline=true

# Network tuning — reduces concurrent connections and gives more time per
# request. Helps in remote environments with restricted or proxied networking.
network-concurrency=3
fetch-timeout=60000
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Bypass the Claude Code proxy (HTTPS_PROXY / CLAUDE_CODE_PROXY_RESOLVES_HOSTS).
# pnpm uses undici which fails with URLSearchParams errors through the proxy;
# direct HTTPS to the npm registry works fine.
noproxy=*
