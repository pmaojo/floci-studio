{
  "name": "floci-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "sidecar:dev": "uv run --project mcp uvicorn floci_backend.server:app --port 8000 --app-dir mcp",
    "dev:full": "docker compose up --build",
    "dev:full:down": "docker compose down",
    "dev:full:reset": "docker compose down -v",
    "build": "vite build",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "smoke:kms": "node scripts/smoke-kms.mjs",
    "mcp:start": "uv run --project mcp python mcp/floci_mcp.py"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1049.0",
    "@aws-sdk/client-cloudformation": "^3.1049.0",
    "@aws-sdk/client-cloudwatch": "^3.1050.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1049.0",
    "@aws-sdk/client-codebuild": "^3.1050.0",
    "@aws-sdk/client-dynamodb": "^3.1049.0",
    "@aws-sdk/client-ec2": "^3.1049.0",
    "@aws-sdk/client-ecr": "^3.1049.0",
    "@aws-sdk/client-ecs": "^3.1049.0",
    "@aws-sdk/client-elasticache": "^3.1049.0",
    "@aws-sdk/client-eventbridge": "^3.1049.0",
    "@aws-sdk/client-glue": "^3.1049.0",
    "@aws-sdk/client-iam": "^3.1049.0",
    "@aws-sdk/client-kinesis": "^3.1049.0",
    "@aws-sdk/client-kms": "^3.1049.0",
    "@aws-sdk/client-lambda": "^3.1049.0",
    "@aws-sdk/client-rds": "^3.1049.0",
    "@aws-sdk/client-s3": "^3.1049.0",
    "@aws-sdk/client-scheduler": "^3.1050.0",
    "@aws-sdk/client-secrets-manager": "^3.1049.0",
    "@aws-sdk/client-ses": "^3.1056.0",
    "@aws-sdk/client-sfn": "^3.1050.0",
    "@aws-sdk/client-sns": "^3.1049.0",
    "@aws-sdk/client-sqs": "^3.1049.0",
    "@aws-sdk/client-ssm": "^3.1050.0",
    "@aws-sdk/client-sts": "^3.1049.0",
    "@aws-sdk/client-wafv2": "^3.1049.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^2.1.9"
  }
}
